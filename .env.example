# 🛡️ SOC Agent - Forensic Vault Edition (v2026)
# Environment Variables Configuration Template

# --- OLLAMA CONNECTION ---
# Use http://localhost:11434 for local machine usage.
# Use the Ubuntu server IP (e.g., http://192.168.x.x:11434) for remote GPU access.
OLLAMA_HOST=http://localhost:11434

# --- MODEL ORCHESTRATION (GPU OPTIMIZED) ---
# 1. Semantic Extractor: Small/Fast model for log-to-JSON parsing (Run on GPU 1)
EXTRACTOR_MODEL=qwen2.5:7b

# 2. Embedding Model: Lightweight model for the RAG Knowledge Base (Run on GPU 1/2)
EMBEDDING_MODEL=nomic-embed-text

# 3. Lead Investigator: DeepSeek-R1 (32B) for Tier 3 reasoning (Run on GPU 3/4)
REPORT_MODEL=deepseek-r1:32b

# --- PERFORMANCE & TIMEOUTS ---
# DeepSeek-R1 requires extra time to 'think' before outputting the report.
# Set in seconds (300 = 5 minutes).
REQUEST_TIMEOUT=300